            p68=0,
            p69=0,
            p70=0,
            p71=0,
            p72=0,
            p73=0,
            p74=1
        },
    }
    for p50=628, 645 do
        ret[#ret+1]={
            ["p50"]=p50,
            ["p69"]=0, --developable (orig. 2)
        }
    end
    return ret
end

return this